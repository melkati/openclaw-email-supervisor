# Runtime data — never commit
data/

# Account configs contain credential references — use templates only
config/accounts/*.json
!config/accounts/_template.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Logs (also under data/, but just in case)
*.log
*.jsonl
